                            "example": "2026-04-01"
                        }
                    },
                    {
                        "name": "end_date",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "format": "date",
                            "example": "2026-04-30"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Riwayat customer berhasil diambil"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/customers/{id}": {
            "get": {
                "tags": [
                    "Customer"
                ],
                "summary": "Detail customer milik sales yang login",
                "description": "Mengambil detail satu customer. Hanya bisa diakses oleh sales pemilik data.",
                "operationId": "d51ce35bfe185b82c242dd4443ffba54",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID customer",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Detail customer berhasil diambil"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "403": {
                        "description": "Customer bukan milik sales yang login"
                    },
                    "404": {
                        "description": "Customer tidak ditemukan"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "Customer"
                ],
                "summary": "Hapus customer (soft delete)",
                "description": "Sales menghapus customer miliknya sendiri. Foto akan dihapus dari storage.",
                "operationId": "634844e24d72540f608f7fd297f5d8b0",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Customer berhasil dihapus"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "403": {
                        "description": "Bukan milik sales yang login"
                    },
                    "404": {
                        "description": "Customer tidak ditemukan"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/profile/photo": {
            "post": {
                "tags": [
                    "Profile"
                ],
                "summary": "Upload foto profil sendiri",
                "description": "User (admin atau sales) mengupload foto profil pribadi. Foto lama akan dihapus jika ada.",
                "operationId": "b225d63d704befc6e6325b03c8623c3f",
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "required": [
                                    "photo"
                                ],
                                "properties": {
                                    "photo": {
                                        "description": "File image (jpeg, jpg, png), max 5 MB",
                                        "type": "string",
                                        "format": "binary"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Foto profil berhasil diupload"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "422": {
                        "description": "File tidak valid"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        }
    },
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "description": "Masukkan token Sanctum tanpa prefix 'Bearer ' (cukup tokennya saja)",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Auth",
            "description": "Endpoint untuk autentikasi user (login & logout)"
        },
        {
            "name": "Customer",
            "description": "Endpoint untuk sales mengelola data customer yang didaftarkan"
        },
        {
            "name": "Admin - Customer",
            "description": "Endpoint khusus admin untuk monitoring seluruh customer dari semua sales"
        },
        {
            "name": "Admin - Sales",
            "description": "Endpoint khusus admin untuk mengelola akun sales (CRUD)"
        },
        {
            "name": "Profile",
            "description": "Endpoint untuk mengelola profil user (foto profil)"
        }
    ]
}