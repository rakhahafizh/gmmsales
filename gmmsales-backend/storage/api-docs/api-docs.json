{
    "openapi": "3.0.0",
    "info": {
        "title": "GMMSales API Documentation",
        "description": "Dokumentasi API untuk aplikasi GMMSales - sistem pencatatan kunjungan customer oleh sales lapangan dengan dokumentasi GPS dan foto.",
        "contact": {
            "name": "Rakha Hafizh",
            "email": "rakhahafizh@example.com"
        },
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://127.0.0.1:8000",
            "description": "GMMSales Local Development Server"
        }
    ],
    "paths": {
        "/api/admin/customers": {
            "get": {
                "tags": [
                    "Admin - Customer"
                ],
                "summary": "Daftar semua customer dari seluruh sales (Admin)",
                "description": "Admin melihat list semua customer beserta info sales yang mendaftarkan. Mendukung filter tanggal dan sales_id.",
                "operationId": "b6f680074bf044ddc711ba76a8607715",
                "parameters": [
                    {
                        "name": "start_date",
                        "in": "query",
                        "description": "Filter tanggal mulai (YYYY-MM-DD)",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "format": "date",
                            "example": "2026-04-01"
                        }
                    },
                    {
                        "name": "end_date",
                        "in": "query",
                        "description": "Filter tanggal akhir (YYYY-MM-DD)",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "format": "date",
                            "example": "2026-04-30"
                        }
                    },
                    {
                        "name": "sales_id",
                        "in": "query",
                        "description": "Filter berdasarkan ID sales tertentu",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "example": 3
                        }
                    },
                    {
                        "name": "page",
                        "in": "query",
                        "description": "Halaman pagination",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Daftar customer berhasil diambil"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "403": {
                        "description": "Bukan role admin"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/admin/customers/{id}": {
            "get": {
                "tags": [
                    "Admin - Customer"
                ],
                "summary": "Detail customer (Admin)",
                "description": "Admin melihat detail lengkap satu customer beserta info sales (termasuk yang sudah dihapus, ditandai dengan is_deleted=true) dan seluruh foto kunjungan.",
                "operationId": "480636e03a521c34eae4ab7b1e7b3c28",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Detail customer berhasil diambil"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "403": {
                        "description": "Bukan role admin"
                    },
                    "404": {
                        "description": "Customer tidak ditemukan"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/admin/sales": {
            "get": {
                "tags": [
                    "Admin - Sales"
                ],
                "summary": "Daftar sales dengan filter (Admin)",
                "description": "Admin melihat list sales dengan dukungan search (nama/username), filter wilayah, dan filter status aktif.",
                "operationId": "4b54ffd4594e487bb4e0fb53e89c17e1",
                "parameters": [
                    {
                        "name": "search",
                        "in": "query",
                        "description": "Cari nama atau username",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "wok_id",
                        "in": "query",
                        "description": "Filter wilayah ID",
                        "required": false,
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "is_active",
                        "in": "query",
                        "description": "Filter status aktif (true/false)",
                        "required": false,
                        "schema": {
                            "type": "boolean"
                        }
                    },
                    {
                        "name": "page",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Daftar sales berhasil diambil"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "403": {
                        "description": "Bukan role admin"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Admin - Sales"
                ],
                "summary": "Tambah akun sales baru (Admin)",
                "description": "Admin membuat akun sales baru. Role otomatis sales, is_active default true, password di-hash.",
                "operationId": "0543d6fd9b676958243637408b875f97",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "username",
                                    "password",
                                    "nomor_telepon",
                                    "wilayah_id"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Eko Saputra"
                                    },
                                    "username": {
                                        "type": "string",
                                        "example": "eko"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "password"
                                    },
                                    "nomor_telepon": {
                                        "type": "string",
                                        "example": "081234567890"
                                    },
                                    "wilayah_id": {
                                        "type": "integer",
                                        "example": 1
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Sales berhasil ditambahkan"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "403": {
                        "description": "Bukan role admin"
                    },
                    "422": {
                        "description": "Validation error (username sudah dipakai, dll)"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/admin/sales/{id}": {
            "get": {
                "tags": [
                    "Admin - Sales"
                ],
                "summary": "Detail sales beserta 3 customer terbaru (Admin)",
                "description": "Admin lihat detail sales lengkap. Untuk semua customer milik sales ini, gunakan GET /api/admin/customers?sales_id={id}.",
                "operationId": "8dc6fc9fa57d07e47233e0ec0100ac53",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Detail sales berhasil diambil"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "403": {
                        "description": "Bukan role admin"
                    },
                    "404": {
                        "description": "Sales tidak ditemukan"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "put": {
                "tags": [
                    "Admin - Sales"
                ],
                "summary": "Edit data sales (Admin)",
                "description": "Admin mengubah data sales: name, nomor_telepon, wilayah_id, is_active, dan password (opsional). Username dan role tidak bisa diubah. Admin tidak bisa nonaktifkan diri sendiri.",
                "operationId": "3e1bcc596776b04ff273d587a1ebf187",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Budi Santoso Updated"
                                    },
                                    "nomor_telepon": {
                                        "type": "string",
                                        "example": "081234567899"
                                    },
                                    "wilayah_id": {
                                        "type": "integer",
                                        "example": 2
                                    },
                                    "is_active": {
                                        "type": "boolean",
                                        "example": true
                                    },
                                    "password": {
                                        "description": "Opsional, untuk reset password",
                                        "type": "string",
                                        "format": "password"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Sales berhasil diupdate"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "403": {
                        "description": "Bukan admin / Admin nonaktifkan diri sendiri"
                    },
                    "404": {
                        "description": "Sales tidak ditemukan"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "Admin - Sales"
                ],
                "summary": "Hapus akun sales (Admin) - soft delete",
                "description": "Admin menghapus sales secara soft delete. Customer milik sales tersebut tetap ada di database. Admin tidak bisa hapus akun sendiri.",
                "operationId": "6110e9f9991475454325e267cd3f509d",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Sales berhasil dihapus"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "403": {
                        "description": "Bukan admin / Admin hapus diri sendiri"
                    },
                    "404": {
                        "description": "Sales tidak ditemukan"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Login user",
                "description": "Autentikasi user dengan username & password. Mengembalikan token Sanctum jika berhasil. Akun yang is_active=false tidak dapat login.",
                "operationId": "a3b306d14572d1f4bd6c064b3233e7b8",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "username",
                                    "password"
                                ],
                                "properties": {
                                    "username": {
                                        "type": "string",
                                        "example": "admin"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "password"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login berhasil"
                    },
                    "401": {
                        "description": "Username atau password salah"
                    },
                    "403": {
                        "description": "Akun dinonaktifkan"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        },
        "/api/logout": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Logout user",
                "description": "Hapus token aktif user yang sedang login.",
                "operationId": "fe8f3429cd6979b3b4517e186505f9f9",
                "responses": {
                    "200": {
                        "description": "Logout berhasil"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/customers": {
            "get": {
                "tags": [
                    "Customer"
                ],
                "summary": "Daftar customer milik sales yang login",
                "description": "Mengambil list customer yang didaftarkan oleh sales yang sedang login. Mendukung pencarian dan pagination.",
                "operationId": "2b23ac696cfd81c23807c2c1fd63b0b0",
                "parameters": [
                    {
                        "name": "search",
                        "in": "query",
                        "description": "Cari berdasarkan nama customer (parsial match)",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "page",
                        "in": "query",
                        "description": "Halaman pagination",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Daftar customer berhasil diambil"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Customer"
                ],
                "summary": "Daftarkan customer baru (Sales)",
                "description": "Sales mendaftarkan customer baru beserta foto kunjungan dan koordinat GPS.",
                "operationId": "428d5533c8386f91d2baf4de69f01468",
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "required": [
                                    "nama_customer",
                                    "alamat",
                                    "nomor_telepon",
                                    "latitude",
                                    "longitude",
                                    "photos"
                                ],
                                "properties": {
                                    "nama_customer": {
                                        "type": "string",
                                        "example": "Toko Jaya Abadi"
                                    },
                                    "alamat": {
                                        "type": "string",
                                        "example": "Jl. Merdeka No. 10"
                                    },
                                    "nomor_telepon": {
                                        "type": "string",
                                        "example": "081234567890"
                                    },
                                    "latitude": {
                                        "type": "number",
                                        "format": "float",
                                        "example": -6.1751
                                    },
                                    "longitude": {
                                        "type": "number",
                                        "format": "float",
                                        "example": 106.865
                                    },
                                    "photos[]": {
                                        "description": "1-3 foto (JPG/PNG, max 5MB per file)",
                                        "type": "array",
                                        "items": {
                                            "type": "string",
                                            "format": "binary"
                                        }
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Customer berhasil didaftarkan"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/customers/history": {
            "get": {
                "tags": [
                    "Customer"
                ],
                "summary": "Riwayat kunjungan customer milik sales yang login",
