                "description": "Admin mengubah data customer secara penuh termasuk koordinat GPS dan foto. Jika field photos dikirim, foto lama akan diganti dengan yang baru (replace all).",
                "operationId": "d0c130ba1854bc1837b6e57ea09177f8",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "properties": {
                                    "nama_customer": {
                                        "type": "string"
                                    },
                                    "alamat": {
                                        "type": "string"
                                    },
                                    "nomor_telepon": {
                                        "type": "string"
                                    },
                                    "latitude": {
